# Flask environment: development | production
FLASK_ENV=development
FLASK_APP=run.py

# Required in production
SECRET_KEY=change-me-to-a-long-random-secret
DATABASE_URL=postgresql://user:password@localhost:5432/mwpp_ministry

# Optional development SQLite (used when DATABASE_URL is unset)
# DATABASE_URL=sqlite:///database/site.db

# Gallery
GALLERY_PER_PAGE=12

# Ministry contact
MINISTRY_EMAIL=womenofpassionandpurpose2024@gmail.com
MINISTRY_PHONE=
MINISTRY_ADDRESS=

# Mail (optional)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=no-reply@ministry.org

# Payments (optional)
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=
FLUTTERWAVE_SECRET_KEY=

# PayPal (optional — international giving)
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_API_URL=https://api-m.sandbox.paypal.com

# Manual payment methods
ZELLE_EMAIL=
CASHAPP_TAG=$WOPPMinistry

# SMS via Twilio (optional — partnership reminders)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# WOP App store links (optional)
APP_STORE_URL=
PLAY_STORE_URL=

# Mobile API write protection (required in production; optional in development)
API_KEY=

# Public site URL (required in production; used for OG images and payment callbacks)
SITE_URL=https://yourdomain.com

# WOPP App Admin — separate system (do NOT deploy this Flask app to this URL)
APP_ADMIN_URL=https://admin.yourdomain.com

# CORS allowlist for /api/v1 (comma-separated)
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Gunicorn (production)
GUNICORN_BIND=0.0.0.0:8000
GUNICORN_WORKERS=2
